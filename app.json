{
  "expo": {
    "name": "sudoStress",
    "slug": "sudoStressApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/imagenes/Icono.png",
    "scheme": "sudostressapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/imagenes/Icono.png"
        // "backgroundImage": "./assets/imagenes/Icono.png"
        // "monochromeImage": "./assets/imagenes/Icono.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.danielcg31.sudoStressApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea2f9114-d30f-4007-804f-4853047faea6"
      }
    }
  }
}
